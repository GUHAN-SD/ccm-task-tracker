    let isCreatingNewClient = false;
    function toggleNewClientInput(showNew) {
      isCreatingNewClient = showNew;
      const select = document.getElementById('modalClientName');
      const container = document.getElementById('newClientInputContainer');
      const toggleBtn = document.getElementById('btnToggleNewClient');
      const input = document.getElementById('modalNewClientName');

      if (showNew) {
        select.style.display = 'none';
        select.required = false;
        container.style.display = 'flex';
        input.required = true;
        input.focus();
        toggleBtn.style.display = 'none';
      } else {
        select.style.display = 'block';
        select.required = true;
        container.style.display = 'none';
        input.required = false;
        input.value = '';
        toggleBtn.style.display = 'block';
      }
    }

    function submitAddTask(e) {
      e.preventDefault();
      const clientName = isCreatingNewClient 
        ? document.getElementById('modalNewClientName').value.trim() 
        : document.getElementById('modalClientName').value;
      const videoTitle = document.getElementById('modalVideoTitle').value.trim();
      const priority = document.getElementById('modalPriority').value;
      let deadline = document.getElementById('modalDeadline').value.trim();
      if (deadline && deadline.includes('-')) {
        deadline = convertYYYYMMDDToDDMMYYYY(deadline);
      }
      const creative = document.getElementById('modalCreative').value;
      const production = document.getElementById('modalProduction').value;
      const editor = document.getElementById('modalEditor').value;

      if (!clientName || !videoTitle) {
        alert('Client Name and Video Title are required.');
        return;
      }

      const btnSubmit = document.getElementById('btnSubmitModal');
      btnSubmit.disabled = true;
      btnSubmit.textContent = 'Creating...';

      callServer('createTask', [clientName, videoTitle, priority, deadline, creative, production, editor], function (result) {
        if (result.ok) {
          // Push new task to DATA array
          DATA.push(result.task);
          
          // Recompute clients
          const counts = {};
          DATA.forEach(t => {
            const c = t['Client Name'];
            if (c) counts[c] = (counts[c] || 0) + 1;
          });
          CLIENTS.length = 0;
          for (const name in counts) {
            CLIENTS.push({ name, count: counts[name] });
          }

          populateFilterOptions();
          closeAddTaskModal();
          renderAll();
          alert('New video task created successfully!');
        }
        btnSubmit.disabled = false;
        btnSubmit.textContent = 'Create Video';
      }, function (err) {
        alert('Failed to create task: ' + (err && err.error ? err.error : JSON.stringify(err)));
        btnSubmit.disabled = false;
        btnSubmit.textContent = 'Create Video';
      });
    }
