  <script>
    const ORIGINAL_DATA = <%- dataJson %>;
    let DATA = [...ORIGINAL_DATA];
    const ROSTER = <%- rosterJson %>;

    let isAssignEditing = false;
    let pendingAssignments = {};
    const CLIENTS = <%- clientsJson %>;
    const ROLE = '<%= role %>';
    const MY_NAME = '<%= personName %>';
    const MY_EMAIL = '<%= userEmail %>';
    const TEAM_ACCOUNTS = <%- typeof teamAccountsJson !== 'undefined' ? teamAccountsJson : '{}' %>;

    const STAGES = [
      { key: 'script', label: 'Script & Storyboard', statusField: 'Script & Storyboard Status', approvalField: 'Script & Storyboard Approval', roleField: 'Creative Team', roleLabel: 'Creative' },
      { key: 'prod', label: 'Image & Video Generation', statusField: 'Image & Video Generation Status', approvalField: 'Image & Video Generation Approval', roleField: 'Production Team', roleLabel: 'Production' },
      { key: 'edit', label: 'Editing', statusField: 'Editing Status', approvalField: 'Editing Approval', roleField: 'Editor', roleLabel: 'Editor' },
    ];
    const GATE_FIELDS = ['Final Internal Approval', 'Client Approval', 'Broadcast Status'];
    const CHECKPOINT_FIELDS = [
      'Script & Storyboard Status', 'Script & Storyboard Approval',
      'Image & Video Generation Status', 'Image & Video Generation Approval',
      'Editing Status', 'Editing Approval',
      'Final Internal Approval', 'Client Approval', 'Broadcast Status'
    ];

    function statusCategory(value) {
      if (!value) return 'not';
      const v = value.toLowerCase().trim();
      if (v.startsWith('not')) return 'not';
      if (v.includes('progress') || v.includes('review') || v.includes('pending') || v.includes('rework') || v.includes('changes') || v.includes('request')) return 'progress';
      return 'done';
    }
    function videoProgressPct(row) {
      let done = 0;
      CHECKPOINT_FIELDS.forEach(f => { if (statusCategory(row[f]) === 'done') done++; });
      return Math.round((done / CHECKPOINT_FIELDS.length) * 100);
    }
    function statusBadge(value, row, fieldKey) {
      if (row && fieldKey) {
        const stage = STAGES.find(s => s.statusField === fieldKey);
        if (stage) {
          const approvalVal = row[stage.approvalField];
          if (value === 'Changes requested') {
            const messageFieldByStage = {
              'Script & Storyboard Status': 'Script & Storyboard Message',
              'Image & Video Generation Status': 'Image & Video Generation Message',
              'Editing Status': 'Editing Message'
            };
            const msgField = messageFieldByStage[fieldKey];
            const comment = msgField ? (row[msgField] || '') : '';
            const onClickAttr = comment ? `onclick="customAlert('Feedback from Admin', '${comment.replace(/'/g, "\\'").replace(/"/g, '&quot;')}')" style="cursor:pointer;" title="Click to view details"` : '';
            return `<span class="badge progress" ${onClickAttr}><span class="dot"></span>Changes requested</span>`;
          }
          if (value === 'Changes in progress') {
            return `<span class="badge progress"><span class="dot"></span>Changes in progress</span>`;
          }
          if (value === 'Completed') {
            if (approvalVal === 'Approved') {
              return `<span class="badge done"><span class="dot"></span>Completed</span>`;
            } else {
              return `<span class="badge critical"><span class="dot"></span>Completed</span>`;
            }
          }
        }
      }
      const cat = statusCategory(value);
      const label = value || '—';
      return `<span class="badge ${cat}"><span class="dot"></span>${label}</span>`;
    }
    function updateLocalRow(videoTitle, field, value) {
      const row = DATA.find(r => r['Video Title'] === videoTitle);
      if (row) row[field] = value;
    }

    // Custom non-blocking visual Toast Notification helper
    function showToast(message, type = 'success') {
      const container = document.getElementById('toast-container');
      if (!container) return;
      
      const toast = document.createElement('div');
      toast.className = `toast-message ${type}`;
      toast.innerHTML = `
        <span style="flex-grow:1;">${message}</span>
        <button style="background:none; border:none; color:var(--text-muted); cursor:pointer; font-size:16px; font-weight:700; padding:0 4px; line-height:1;" onclick="this.parentElement.remove()">×</button>
      `;
      container.appendChild(toast);
      
      // Auto-remove after 3.2 seconds
      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translateY(10px)';
        setTimeout(() => toast.remove(), 300);
      }, 3200);
    }

    // Custom non-blocking Alert Dialog helper
    function customAlert(title, message) {
      const modal = document.getElementById('confirmModal');
      const titleEl = document.getElementById('confirmTitle');
      const msgEl = document.getElementById('confirmMessage');
      const okBtn = document.getElementById('confirmOkBtn');
      const cancelBtn = document.getElementById('confirmCancelBtn');
      
      titleEl.textContent = title;
      
      // Parse Voice Note tag
      let finalMessage = message || '';
      let audioHtml = '';
      
      const match = finalMessage.match(/^\[Voice Note:([^\]]+)\]\s*(.*)/);
      if (match) {
        const audioUrl = match[1];
        finalMessage = match[2];
        audioHtml = `
          <div style="margin-top:12px; margin-bottom:12px; display:flex; justify-content:center;">
            <audio controls src="${audioUrl}" style="height:36px; max-width:280px;"></audio>
          </div>
        `;
      }
      
      msgEl.innerHTML = `<div>${finalMessage}</div>${audioHtml}`;
      modal.style.display = 'flex';
      
      // Configure elements temporarily as an alert box
      cancelBtn.style.display = 'none';
      okBtn.textContent = 'Close';
      okBtn.className = 'btn primary';
      
      okBtn.onclick = function() {
        modal.style.display = 'none';
        // restore buttons defaults
        cancelBtn.style.display = 'inline-block';
        okBtn.textContent = 'Yes, Proceed';
        okBtn.className = 'btn reject';
      };
    }

    // Custom non-blocking Confirmation Modal helper
    function customConfirm(title, message, onConfirm) {
      const modal = document.getElementById('confirmModal');
      const titleEl = document.getElementById('confirmTitle');
      const msgEl = document.getElementById('confirmMessage');
      const okBtn = document.getElementById('confirmOkBtn');
      const cancelBtn = document.getElementById('confirmCancelBtn');
      
      titleEl.textContent = title;
      msgEl.textContent = message;
      modal.style.display = 'flex';
      
      okBtn.onclick = function() {
        modal.style.display = 'none';
        onConfirm();
      };
      
      cancelBtn.onclick = function() {
        modal.style.display = 'none';
      };
    }

    // Custom non-blocking Prompt Modal helper for input fields
    let mediaRecorder = null;
    let audioChunks = [];
    let recordedAudioBase64 = '';
    let recTimer = null;
    let recSeconds = 0;

    function customPrompt(title, defaultValue, onSubmit, showVoice = false) {
      const modal = document.getElementById('promptModal');
      const titleEl = document.getElementById('promptTitle');
      const inputEl = document.getElementById('promptInput');
      const okBtn = document.getElementById('promptOkBtn');
      const cancelBtn = document.getElementById('promptCancelBtn');
      
      // Voice section elements
      const voiceSec = document.getElementById('promptVoiceSection');
      const btnStart = document.getElementById('btnStartRec');
      const btnStop = document.getElementById('btnStopRec');
      const preview = document.getElementById('audioPreview');
      const statusEl = document.getElementById('recStatus');
      const indicator = document.getElementById('recIndicator');
      
      titleEl.textContent = title;
      inputEl.value = defaultValue || '';
      modal.style.display = 'flex';
      setTimeout(() => inputEl.focus(), 50);
      
      // Reset recording state
      recordedAudioBase64 = '';
      if (recTimer) clearInterval(recTimer);
      statusEl.textContent = 'Voice feedback is optional';
      indicator.style.backgroundColor = 'var(--text-muted)';
      btnStart.style.display = 'inline-flex';
      btnStart.textContent = '🎤 Record';
      btnStop.style.display = 'none';
      preview.style.display = 'none';
      preview.src = '';
      
      if (showVoice) {
        voiceSec.style.display = 'block';
      } else {
        voiceSec.style.display = 'none';
      }
      
      // Start recording
      btnStart.onclick = async function() {
        try {
          const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
          audioChunks = [];
          
          let options = { mimeType: 'audio/webm' };
          if (!MediaRecorder.isTypeSupported('audio/webm')) {
            options = { mimeType: 'audio/mp4' };
          }
          
          mediaRecorder = new MediaRecorder(stream, options);
          mediaRecorder.ondataavailable = e => {
            if (e.data.size > 0) {
              audioChunks.push(e.data);
            }
          };
          
          mediaRecorder.onstop = () => {
            const blob = new Blob(audioChunks, { type: options.mimeType });
            const audioUrl = URL.createObjectURL(blob);
            preview.src = audioUrl;
            preview.style.display = 'block';
            
            const reader = new FileReader();
            reader.readAsDataURL(blob);
            reader.onloadend = () => {
              recordedAudioBase64 = reader.result;
            };
            
            stream.getTracks().forEach(track => track.stop());
          };
          
          mediaRecorder.start();
          
          btnStart.style.display = 'none';
          btnStop.style.display = 'inline-flex';
          indicator.style.backgroundColor = 'var(--critical)';
          recSeconds = 0;
          statusEl.textContent = 'Recording: 0s';
          
          recTimer = setInterval(() => {
            recSeconds++;
            statusEl.textContent = `Recording: ${recSeconds}s`;
          }, 1000);
          
        } catch (err) {
          console.error(err);
          showToast('Could not access microphone: ' + err.message, 'error');
        }
      };
      
      // Stop recording
      btnStop.onclick = function() {
        if (mediaRecorder && mediaRecorder.state !== 'inactive') {
          mediaRecorder.stop();
        }
        if (recTimer) clearInterval(recTimer);
        btnStop.style.display = 'none';
        btnStart.style.display = 'inline-flex';
        btnStart.textContent = '🎤 Record Again';
        indicator.style.backgroundColor = 'var(--good)';
        statusEl.textContent = 'Recording saved!';
      };
      
      // Handle Enter keypress in prompt input
      inputEl.onkeydown = function(e) {
        if (e.key === 'Enter') {
          okBtn.click();
        }
      };
      
      okBtn.onclick = function() {
        if (mediaRecorder && mediaRecorder.state !== 'inactive') {
          mediaRecorder.stop();
        }
        if (recTimer) clearInterval(recTimer);
        
        const textVal = inputEl.value.trim();
        
        if (recordedAudioBase64) {
          okBtn.disabled = true;
          okBtn.textContent = 'Saving...';
          
          fetch('/api/uploadAudio', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ audioBase64: recordedAudioBase64 })
          })
          .then(res => res.json())
          .then(data => {
            okBtn.disabled = false;
            okBtn.textContent = 'Save';
            modal.style.display = 'none';
            if (data.url) {
              const finalComment = `[Voice Note:${data.url}] ${textVal}`;
              onSubmit(finalComment);
            } else {
              onSubmit(textVal);
            }
          })
          .catch(err => {
            console.error(err);
            okBtn.disabled = false;
            okBtn.textContent = 'Save';
            modal.style.display = 'none';
            showToast('Failed to upload audio, sending text comment only.', 'info');
            onSubmit(textVal);
          });
        } else {
          modal.style.display = 'none';
          onSubmit(textVal);
        }
      };
      
      cancelBtn.onclick = function() {
        if (mediaRecorder && mediaRecorder.state !== 'inactive') {
          mediaRecorder.stop();
        }
        if (recTimer) clearInterval(recTimer);
        modal.style.display = 'none';
      };
    }

    function flashSaved(el) {
      if (!el) return;
      let flash = el.parentElement.querySelector('.saved-flash');
      if (!flash) {
        flash = document.createElement('span');
        flash.className = 'saved-flash';
        flash.textContent = '✓ saved';
        el.parentElement.appendChild(flash);
      }
      flash.classList.add('show');
      setTimeout(() => flash.classList.remove('show'), 1400);
    }

    // Talks to the Node/Express backend instead of google.script.run
    function callServer(fnName, args, onSuccess, onFailure) {
      const endpointByFn = {
        markComplete: { url: '/api/markComplete', argNames: ['videoTitle', 'stageKey'] },
        startProgress: { url: '/api/startProgress', argNames: ['videoTitle', 'stageKey'] },
        approveStage: { url: '/api/approveStage', argNames: ['videoTitle', 'stageKey', 'decision', 'comment'] },
        setGateStatus: { url: '/api/setGateStatus', argNames: ['videoTitle', 'columnName', 'value'] },
        assignPerson: { url: '/api/assignPerson', argNames: ['videoTitle', 'roleCol', 'personName'] },
        createTask: { url: '/api/createTask', argNames: ['clientName', 'videoTitle', 'priority', 'deadline', 'creative', 'production', 'editor'] },
        resetUserPassword: { url: '/api/resetUserPassword', argNames: ['email'] },
        deleteTask: { url: '/api/deleteTask', argNames: ['videoTitle'] },
        startChanges: { url: '/api/startChanges', argNames: ['videoTitle', 'stageKey'] },
        updateStageLink: { url: '/api/updateStageLink', argNames: ['videoTitle', 'linkField', 'linkUrl'] },
        addTeamMember: { url: '/api/addTeamMember', argNames: ['name', 'team', 'email'] },
        deleteTeamMember: { url: '/api/deleteTeamMember', argNames: ['name', 'email'] },
      };
      const conf = endpointByFn[fnName];
      if (!conf) { console.error('Unknown server function', fnName); return; }
      const body = {};
      conf.argNames.forEach((name, i) => { body[name] = args[i]; });

      fetch(conf.url, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify(body),
      })
        .then(res => {
          if (!res.ok) return res.json().then(e => Promise.reject(e));
          return res.json();
        })
        .then(result => { onSuccess && onSuccess(result); })
        .catch(err => {
          if (onFailure) {
            onFailure(err);
          } else {
            alert('Could not save: ' + (err && err.error ? err.error : JSON.stringify(err)));
          }
        });
    }

    // ---------- Actions ----------
    function handleStartProgress(videoTitle, stageKey) {
      const stage = STAGES.find(s => s.key === stageKey);
      callServer('startProgress', [videoTitle, stageKey], function () {
        updateLocalRow(videoTitle, stage.statusField, 'In progress');
        renderAll();
      });
    }
    function handleStartChanges(videoTitle, stageKey) {
      const stage = STAGES.find(s => s.key === stageKey);
      callServer('startChanges', [videoTitle, stageKey], function () {
        updateLocalRow(videoTitle, stage.statusField, 'Changes in progress');
        renderAll();
      });
    }
    function handleMarkComplete(videoTitle, stageKey) {
      const stage = STAGES.find(s => s.key === stageKey);
      callServer('markComplete', [videoTitle, stageKey], function () {
        const pad = (n) => String(n).padStart(2, '0');
        const d = new Date();
        const timestamp = pad(d.getDate()) + '/' + pad(d.getMonth() + 1) + '/' + d.getFullYear() + ' ' + pad(d.getHours()) + ':' + pad(d.getMinutes());
        updateLocalRow(videoTitle, stage.statusField, 'Completed');

        const finishedDateFieldByStage = {
          script: 'Script & Storyboard Status - Finished Date',
          prod: 'Image & Video Generation Status - Finished Date',
          edit: 'Editing Status - Finished Date',
        };
        updateLocalRow(videoTitle, finishedDateFieldByStage[stageKey], timestamp);
        renderAll();
      });
    }
    function handleApprove(videoTitle, stageKey, decision) {
      const stage = STAGES.find(s => s.key === stageKey);
      
      const proceedApproval = (comment = '') => {
        callServer('approveStage', [videoTitle, stageKey, decision, comment], function () {
          const messageFieldByStage = {
            script: 'Script & Storyboard Message',
            prod: 'Image & Video Generation Message',
            edit: 'Editing Message'
          };
          if (decision === 'approve') {
            updateLocalRow(videoTitle, stage.approvalField, 'Approved');
            updateLocalRow(videoTitle, stage.statusField, 'Completed');
            updateLocalRow(videoTitle, messageFieldByStage[stageKey], '');
          } else {
            updateLocalRow(videoTitle, stage.approvalField, 'Changes requested');
            updateLocalRow(videoTitle, stage.statusField, 'Changes requested');
            updateLocalRow(videoTitle, messageFieldByStage[stageKey], comment);
          }
          renderAll();
          showToast(decision === 'approve' ? 'Stage approved successfully!' : 'Stage sent back for changes successfully!', 'success');
        });
      };
      
      if (decision === 'reject') {
        customPrompt('Please enter details/comments on what changes are requested:', '', function(comment) {
          if (!comment) return; // cancelled or empty prompt
          proceedApproval(comment);
        }, true);
      } else {
        proceedApproval();
      }
    }
    function handleGate(videoTitle, columnName, value) {
      callServer('setGateStatus', [videoTitle, columnName, value], function () {
        updateLocalRow(videoTitle, columnName, value);
        renderAll();
      });
    }
    function handleAssign(videoTitle, roleCol, personName, selectEl) {
      callServer('assignPerson', [videoTitle, roleCol, personName], function () {
        updateLocalRow(videoTitle, roleCol, personName);
        renderAll();
        flashSaved(selectEl);
      });
    }

