          actionCell = '<span class="badge done"><span class="dot"></span>Approved</span>';
        } else if (statusVal === 'Completed') {
          actionCell = '<span class="badge progress"><span class="dot"></span>Waiting for approval</span>';
        } else if (statusVal === 'Changes requested') {
          const messageFieldByStage = {
            script: 'Script & Storyboard Message',
            prod: 'Image & Video Generation Message',
