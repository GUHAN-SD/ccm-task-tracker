          };
          const msgField = messageFieldByStage[stage.key];
          const comment = msgField ? (row[msgField] || '') : '';
          const onClickAttr = comment ? `onclick="customAlert('Feedback from Admin', '${comment.replace(/'/g, "\\'").replace(/"/g, '&quot;')}')" style="cursor:pointer; margin-right:8px;" title="Click to view details"` : 'style="margin-right:8px;"';
          actionCell = `<span class="badge progress" ${onClickAttr}><span class="dot"></span>Changes requested</span>` +
                       `<button class="btn small primary" onclick="handleStartChanges('${row['Video Title'].replace(/'/g, "\\'")}','${stage.key}')">▶ Start Changes</button>`;
        } else if (statusVal === 'Changes in progress') {
          actionCell = `<span class="badge progress" style="margin-right:8px;"><span class="dot"></span>Changes in progress</span>` +
                       `<button class="btn small primary" onclick="handleMarkComplete('${row['Video Title'].replace(/'/g, "\\'")}','${stage.key}')">✓ Changes Completed</button>`;
        } else if (statusVal === 'In progress') {
          actionCell = `<button class="btn small primary" onclick="handleMarkComplete('${row['Video Title'].replace(/'/g, "\\'")}','${stage.key}')">✓ Mark Complete</button>`;
        } else {
          // not started / empty / needs rework
          actionCell = `<button class="btn small primary" onclick="handleStartProgress('${row['Video Title'].replace(/'/g, "\\'")}','${stage.key}')">▶ Start Progress</button>`;
          if (statusVal === 'Needs rework') {
            actionCell = '<span class="badge progress" style="margin-right:6px"><span class="dot"></span>Sent back</span>' + actionCell;
          }
        }

        const priority = row['Priority'] || 'Normal';
        let priorityClass = 'not';
        if (priority === 'High') priorityClass = 'progress';
        const priorityBadge = `<span class="badge ${priorityClass}">${priority}</span>`;

        const linkFields = {
          script: 'Creative Link',
          prod: 'Production Link',
          edit: 'Editor Link'
        };
        const linkField = linkFields[stage.key];
        const linkUrl = row[linkField] || '';
        const linkHtml = getLinkIconHtml(row['Video Title'], linkField, linkUrl, true);

        return `<tr>
