    // ---------- Global Month/Year Filters ----------
    function applyGlobalFilters() {
      const monthSel = document.getElementById('globalMonthSelect').value;
      const yearInput = document.getElementById('globalYearInput').value.trim();

      DATA = ORIGINAL_DATA.filter(row => {
        const deadline = (row['Deadline'] || '').trim();

        if (!deadline) {
          return !monthSel && !yearInput;
        }

        const parts = deadline.split('/');
        if (parts.length < 3) {
          return !monthSel && !yearInput;
        }

        const monthNum = parseInt(parts[1], 10);
        const year = parts[2].trim();
        const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
        const monthName = (monthNum >= 1 && monthNum <= 12) ? months[monthNum - 1] : '';

        const matchesMonth = !monthSel || monthName === monthSel;
        const matchesYear = !yearInput || year.includes(yearInput);
        return matchesMonth && matchesYear;
      });

      renderAll();
    }

    // ---------- Init ----------
    renderWhoAmI();
