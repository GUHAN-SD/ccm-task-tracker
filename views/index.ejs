    function getFilteredTasks() {
      const search = document.getElementById('taskSearch').value.toLowerCase().trim();
      const client = document.getElementById('filterClient').value;
      const assigneeEl = document.getElementById('filterAssignee');
      const stageKeyEl = document.getElementById('filterStage');
      const statusValEl = document.getElementById('filterStatus');
      const assignee = assigneeEl ? assigneeEl.value : '';
      const stageKey = stageKeyEl ? stageKeyEl.value : '';
      const statusVal = statusValEl ? statusValEl.value : '';
      return DATA.filter(row => {
        if (client && row['Client Name'] !== client) return false;
        if (assignee && row['Creative Team'] !== assignee && row['Production Team'] !== assignee && row['Editor'] !== assignee) return false;
        if (search) {
          const hay = (row['Client Name'] + ' ' + row['Video Title'] + ' ' + row['Creative Team'] + ' ' + row['Production Team'] + ' ' + row['Editor']).toLowerCase();
          if (!hay.includes(search)) return false;
        }
        if (stageKey) {
          const stage = STAGES.find(s => s.key === stageKey);
          const field = stage ? stage.statusField : stageKey;
          if (statusVal && statusCategory(row[field]) !== statusVal) return false;
        } else if (statusVal) {
          const anyMatch = CHECKPOINT_FIELDS.some(f => statusCategory(row[f]) === statusVal);
          if (!anyMatch) return false;
        }
        return true;
      });
    }
    function renderTaskTable() {
      const cols = TASK_COLUMNS;
      const head = document.getElementById('taskTableHead');
      head.innerHTML = cols.map(c => `<th data-key="${c.key}">${c.label} ${taskSort.key === c.key ? (taskSort.dir === 1 ? '▲' : '▼') : ''}</th>`).join('');
      head.querySelectorAll('th').forEach(th => {
        th.onclick = () => {
          const key = th.dataset.key;
          if (taskSort.key === key) taskSort.dir *= -1; else { taskSort.key = key; taskSort.dir = 1; }
          renderTaskTable();
        };
      });
      let rows = getFilteredTasks();
      rows = rows.slice().sort((a, b) => (a[taskSort.key] || '').localeCompare(b[taskSort.key] || '') * taskSort.dir);
      document.getElementById('taskCount').textContent = `Showing ${rows.length} of ${DATA.length} videos`;
      const body = document.getElementById('taskTableBody');
      body.innerHTML = rows.map(row => '<tr>' + cols.map(c => {
        if (c.key.includes('Status') || c.key === 'Final Internal Approval' || c.key === 'Client Approval') {
          return `<td>${statusBadge(row[c.key], row, c.key)}</td>`;
        }
        if (c.key === 'Creative Link' || c.key === 'Production Link' || c.key === 'Editor Link') {
          const linkUrl = row[c.key] || '';
          let linkHtml = '';
          if (linkUrl) {
            linkHtml = `<span class="link-btn" onclick="window.open('${linkUrl.replace(/'/g, "\\'")}', '_blank'); event.stopPropagation();" title="Open link: ${linkUrl}" style="cursor:pointer; display:inline-flex; align-items:center; vertical-align:middle;">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
            </span>`;
          } else {
            linkHtml = '<span style="color:var(--text-muted)">—</span>';
          }
          return `<td style="text-align:center;">${linkHtml}</td>`;
        }
        return `<td>${row[c.key] || '<span style="color:var(--text-muted)">—</span>'}</td>`;
      }).join('') + '</tr>').join('') || `<tr><td colspan="${cols.length}"><div class="empty-state">No videos match these filters.</div></td></tr>`;
    }
    function exportCsv() {
      const rows = getFilteredTasks();
      const headers = TASK_COLUMNS.map(c => c.label);
      const lines = [headers.join(',')];
      rows.forEach(r => lines.push(TASK_COLUMNS.map(c => '"' + (r[c.key] || '').toString().replace(/"/g, '""') + '"').join(',')));
      const blob = new Blob([lines.join('\n')], { type: 'text/csv' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url; a.download = 'ccm-tracker-filtered.csv';
      document.body.appendChild(a); a.click(); a.remove();
      URL.revokeObjectURL(url);
    }

    // ---------- Approvals (admin) ----------
    function renderApprovals() {
      if (ROLE !== 'admin') return;

      const client = document.getElementById('approvalsFilterClient').value;
      const assignee = document.getElementById('approvalsFilterAssignee').value;

      // 1. Get all videos that have at least one stage pending approval
      let pendingVideos = DATA.filter(row => {
        return STAGES.some(stage => {
          return row[stage.statusField] === 'Completed' && row[stage.approvalField] !== 'Approved';
        });
      });

      // Apply filters
      if (client) {
        pendingVideos = pendingVideos.filter(row => row['Client Name'] === client);
      }
      if (assignee) {
        pendingVideos = pendingVideos.filter(row =>
          row['Creative Team'] === assignee ||
          row['Production Team'] === assignee ||
          row['Editor'] === assignee
        );
      }

      // Render Stage approvals table body
      document.getElementById('approvalsBody').innerHTML = pendingVideos.map(row => {
        const vt = row['Video Title'].replace(/'/g, "\\'");

        const renderCell = (stage) => {
          const linkFields = {
            script: 'Creative Link',
            prod: 'Production Link',
            edit: 'Editor Link'
          };
          const linkField = linkFields[stage.key];
          const linkUrl = row[linkField] || '';
          
          let linkHtml = '';
          if (linkUrl) {
            linkHtml = `<span class="link-btn" onclick="window.open('${linkUrl.replace(/'/g, "\\'")}', '_blank'); event.stopPropagation();" title="Open link: ${linkUrl}" style="cursor:pointer; display:inline-flex; align-items:center; margin-left:6px; vertical-align:middle;">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
            </span>`;
          }

          if (row[stage.approvalField] === 'Approved') {
            return `<div style="display:flex; align-items:center; justify-content:flex-start; gap:6px;">
              ${statusBadge('Approved')}
              ${linkHtml}
            </div>`;
          }
          if (row[stage.statusField] === 'Completed') {
            const isChangeSubmission = row[stage.approvalField] === 'Changes requested';
            const approveText = isChangeSubmission ? 'Approve changes' : 'Approve';
            return `
              <div class="action-cell" style="display:flex; flex-direction:column; gap:6px; align-items:flex-start; min-width:140px;">
                <span style="font-size:11px; color:var(--text-muted); font-weight:600; display:inline-flex; align-items:center; gap:6px;">
                  ${row[stage.roleField] || 'Unassigned'}
                  ${linkHtml}
                </span>
                <div style="display:flex; gap:6px;">
                  <button class="btn small approve" onclick="handleApprove('${vt}','${stage.key}','approve')">${approveText}</button>
                  <button class="btn small reject" onclick="handleApprove('${vt}','${stage.key}','reject')">Send back</button>
                </div>
              </div>
            `;
          }
          const status = row[stage.statusField] || 'Not started';
          const person = row[stage.roleField] || '—';
          return `
            <div style="display:flex; flex-direction:column; gap:4px; align-items:flex-start;">
              <div style="display:flex; align-items:center; justify-content:flex-start; gap:6px;">
                ${statusBadge(status, row, stage.statusField)}
                ${linkHtml}
              </div>
              <span style="font-size:11px; color:var(--text-muted);">${person}</span>
            </div>
          `;
        };

        return `<tr>
          <td>${row['Client Name']}</td>
          <td>${row['Video Title']}</td>
          <td>${renderCell(STAGES[0])}</td>
          <td>${renderCell(STAGES[1])}</td>
          <td>${renderCell(STAGES[2])}</td>
        </tr>`;
      }).join('') || `<tr><td colspan="5"><div class="empty-state">No stages waiting on approval right now.</div></td></tr>`;

      // 2. Gates table filtering
      let gateEligible = DATA.filter(row => STAGES.every(s => row[s.approvalField] === 'Approved'));
      if (client) {
        gateEligible = gateEligible.filter(row => row['Client Name'] === client);
      }
      if (assignee) {
        gateEligible = gateEligible.filter(row =>
          row['Creative Team'] === assignee ||
          row['Production Team'] === assignee ||
          row['Editor'] === assignee
        );
      }

      document.getElementById('gatesBody').innerHTML = gateEligible.map(row => {
        const vt = row['Video Title'].replace(/'/g, "\\'");
        const finalBtn = row['Final Internal Approval'] === 'Approved' ? statusBadge('Approved') :
          `<button class="btn small approve" onclick="handleGate('${vt}','Final Internal Approval','Approved')">Approve</button>`;
        const clientBtn = row['Client Approval'] === 'Approved' ? statusBadge('Approved') :
          `<button class="btn small approve" onclick="handleGate('${vt}','Client Approval','Approved')">Approve</button>`;
        const broadcastBtn = statusCategory(row['Broadcast Status']) === 'done' ? statusBadge(row['Broadcast Status']) :
          `<button class="btn small approve" onclick="handleGate('${vt}','Broadcast Status','Broadcasted')">Mark Broadcasted</button>`;
        return `<tr>
      <td>${row['Client Name']}</td>
      <td>${row['Video Title']}</td>
      <td>${finalBtn}</td>
      <td>${clientBtn}</td>
      <td>${broadcastBtn}</td>
    </tr>`;
      }).join('') || `<tr><td colspan="5"><div class="empty-state">No videos matching filters have all 3 stages approved.</div></td></tr>`;
    }

    // ---------- Client Approvals ----------
    function renderClientApprovals() {
      if (ROLE !== 'admin') return;
      const body = document.getElementById('clientApprovalsBody');
      if (!body) return;
      
      body.innerHTML = DATA.map(row => {
        const vt = row['Video Title'].replace(/'/g, "\\'");
        const clientApprovalStatus = row['Client Approval'] || 'Not started';
        const editorLink = row['Editor Link'] || '';
        
        let linkHtml = '';
        if (editorLink) {
          linkHtml = `<span class="link-btn" onclick="window.open('${editorLink.replace(/'/g, "\\'")}', '_blank'); event.stopPropagation();" title="Open final video: ${editorLink}" style="cursor:pointer; display:inline-flex; align-items:center; vertical-align:middle;">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
          </span>`;
        } else {
          linkHtml = '<span style="color:var(--text-muted); font-size:11px;">—</span>';
        }
        
        let statusBadgeClass = 'not';
        if (clientApprovalStatus === 'Approved') statusBadgeClass = 'good';
        if (clientApprovalStatus === 'Changes requested') statusBadgeClass = 'urgent';
        if (clientApprovalStatus === 'Under Review') statusBadgeClass = 'progress';
        
        const badge = `<span class="badge ${statusBadgeClass}">${clientApprovalStatus}</span>`;
        
        // Actions
        const actions = `
          <div style="display:flex; gap:6px;">
            <button class="btn small good" onclick="handleSetGateStatusDirect('${vt}', 'Client Approval', 'Approved')">✓ Approve</button>
            <button class="btn small reject" onclick="handleClientRework('${vt}')">❌ Rework</button>
            <button class="btn small primary" onclick="handleSetGateStatusDirect('${vt}', 'Client Approval', 'Under Review')">⏳ Sent to Client</button>
          </div>
        `;
        
        return `<tr>
          <td>${row['Client Name']}</td>
          <td>${row['Video Title']}</td>
          <td style="text-align:center;">${linkHtml}</td>
          <td>${badge}</td>
          <td>${actions}</td>
        </tr>`;
      }).join('') || `<tr><td colspan="5"><div class="empty-state">No videos found.</div></td></tr>`;
    }

    function handleSetGateStatusDirect(videoTitle, columnName, value) {
      callServer('setGateStatus', [videoTitle, columnName, value], function () {
        const row = DATA.find(r => r['Video Title'] === videoTitle);
        if (row) {
          row[columnName] = value;
        }
        renderAll();
        showToast(`${columnName} status updated to ${value}!`, 'success');
      }, function (err) {
        showToast('Failed to update status: ' + (err && err.error ? err.error : JSON.stringify(err)), 'error');
      });
    }

    function handleClientRework(videoTitle) {
      customPrompt('Enter client feedback / changes requested:', '', function(comment) {
        if (!comment) return; // cancel or empty submit does nothing
        
        // We set Client Approval to 'Changes requested'
        callServer('setGateStatus', [videoTitle, 'Client Approval', 'Changes requested'], function() {
          const row = DATA.find(r => r['Video Title'] === videoTitle);
          if (row) {
            row['Client Approval'] = 'Changes requested';
            row['Editing Status'] = 'Needs rework';
            row['Editing Message'] = comment;
          }
          
          // Let's notify the backend about the editor rework
          callServer('approveStage', [videoTitle, 'edit', 'reject', comment], function() {
            renderAll();
            showToast('Client feedback sent back to Editor successfully!', 'success');
          }, function(err) {
            renderAll();
            showToast('Updated Client Approval, but failed to automatically update Editor status.', 'info');
          });
          
        }, function(err) {
          showToast('Failed to update Client Approval status: ' + (err && err.error ? err.error : JSON.stringify(err)), 'error');
        });
      }, true);
    }

    // ---------- Assign (admin) ----------
    function startAssignEdit() {
      isAssignEditing = true;
      pendingAssignments = {};
      renderAssignTab();
    }
    function cancelAssignments() {
      isAssignEditing = false;
      pendingAssignments = {};
      renderAssignTab();
    }
    function handleAssignChange(videoTitle, roleCol, newPerson) {
      const key = `${videoTitle}|${roleCol}`;
      pendingAssignments[key] = newPerson;
      const btnApply = document.getElementById('btnAssignApply');
      if (btnApply) {
        btnApply.disabled = Object.keys(pendingAssignments).length === 0;
      }
    }
    function handlePriorityChange(videoTitle, newPriority) {
      const key = `${videoTitle}|Priority`;
      pendingAssignments[key] = newPriority;
      const btnApply = document.getElementById('btnAssignApply');
      if (btnApply) {
        btnApply.disabled = Object.keys(pendingAssignments).length === 0;
      }
    }
    function handleDeadlineChange(videoTitle, newDeadline) {
      const key = `${videoTitle}|Deadline`;
      pendingAssignments[key] = newDeadline;
      const btnApply = document.getElementById('btnAssignApply');
      if (btnApply) {
        btnApply.disabled = Object.keys(pendingAssignments).length === 0;
      }
    }
    function applyAssignments() {
      const keys = Object.keys(pendingAssignments);
      if (keys.length === 0) return;

      const btnApply = document.getElementById('btnAssignApply');
      const btnCancel = document.getElementById('btnAssignCancel');
      btnApply.textContent = 'Saving...';
      btnApply.disabled = true;
      btnCancel.disabled = true;

      let index = 0;

      function saveNext() {
        if (index >= keys.length) {
          pendingAssignments = {};
          isAssignEditing = false;
          renderAll();
          showToast('Assignments saved successfully!', 'success');
          return;
        }

        const key = keys[index];
        const [videoTitle, roleCol] = key.split('|');
        const personName = pendingAssignments[key];

        callServer('assignPerson', [videoTitle, roleCol, personName], function () {
          updateLocalRow(videoTitle, roleCol, personName);
          index++;
          saveNext();
        }, function (err) {
          showToast('Failed to save assignments: ' + (err && err.error ? err.error : JSON.stringify(err)), 'error');
          btnApply.textContent = '✓ Apply';
          btnApply.disabled = false;
          btnCancel.disabled = false;
        });
      }

      saveNext();
    }
    function priorityDropdown(row) {
      const key = `${row['Video Title']}|Priority`;
      const selectedValue = (key in pendingAssignments) ? pendingAssignments[key] : (row['Priority'] || 'Normal');
      const vt = row['Video Title'].replace(/'/g, "\\'");

      if (!isAssignEditing) {
        let priorityClass = 'not';
        if (selectedValue === 'High') priorityClass = 'progress';
        return `<span class="badge ${priorityClass}">${selectedValue}</span>`;
      }

      const options = ['Normal', 'High'].map(opt =>
        `<option value="${opt}" ${selectedValue === opt ? 'selected' : ''}>${opt}</option>`
      );
      return `<select class="assign-select" onchange="handlePriorityChange('${vt}', this.value)">${options.join('')}</select>`;
    }

    function convertDDMMYYYYToYYYYMMDD(str) {
      if (!str) return '';
      const parts = str.trim().split('/');
      if (parts.length !== 3) return '';
      const day = parts[0].padStart(2, '0');
      const month = parts[1].padStart(2, '0');
      const year = parts[2];
      return `${year}-${month}-${day}`;
    }

    function convertYYYYMMDDToDDMMYYYY(str) {
      if (!str) return '';
      const parts = str.trim().split('-');
      if (parts.length !== 3) return '';
      const year = parts[0];
      const month = parts[1].padStart(2, '0');
      const day = parts[2].padStart(2, '0');
      return `${day}/${month}/${year}`;
    }

    function deadlineInput(row) {
      const key = `${row['Video Title']}|Deadline`;
      const selectedValue = (key in pendingAssignments) ? pendingAssignments[key] : (row['Deadline'] || '');
      const vt = row['Video Title'].replace(/'/g, "\\'");

      if (!isAssignEditing) {
        return selectedValue || '<span style="color:var(--text-muted)">—</span>';
      }

      const dateVal = convertDDMMYYYYToYYYYMMDD(selectedValue);
      return `<input type="date" class="deadline-input" value="${dateVal}" onchange="handleDeadlineChange('${vt}', convertYYYYMMDDToDDMMYYYY(this.value))" style="width:115px; padding:5px 7px; font-size:12px; border-radius:6px; border:1px solid var(--border); background:var(--surface-2); color:var(--text-primary); text-align:center; font-family:inherit;">`;
    }

    function getLinkIconHtml(videoTitle, linkField, currentUrl, canEdit) {
      const activeColor = currentUrl ? 'var(--accent)' : 'var(--text-muted)';
      const opacity = currentUrl ? '1' : '0.4';
      const titleAttr = currentUrl ? `title="Open link: ${currentUrl}"` : 'title="No link added yet"';
      
      let clickAction = '';
      if (currentUrl) {
        clickAction = `onclick="window.open('${currentUrl.replace(/'/g, "\\'")}', '_blank'); event.stopPropagation();"`;
      } else {
        clickAction = `onclick="alert('No link has been added yet.'); event.stopPropagation();"`;
      }
      
      const globeSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="${activeColor}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-globe" style="vertical-align: middle; opacity: ${opacity};"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>`;
      
      let editBtnHtml = '';
      if (canEdit) {
        const editSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="var(--text-muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-edit-2" style="vertical-align: middle;"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path></svg>`;
        editBtnHtml = `<span class="edit-link-icon" onclick="handleEditLink(event, '${videoTitle.replace(/'/g, "\\'")}', '${linkField}', '${(currentUrl || '').replace(/'/g, "\\'")}')" title="Edit Link" style="cursor:pointer; margin-left:6px; display:inline-flex; align-items:center; opacity:0.7;" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0.7">${editSvg}</span>`;
      }
      
      return `<span style="display:inline-flex; align-items:center; gap:2px; vertical-align:middle;">
        <span class="link-btn" ${clickAction} ${titleAttr} style="cursor:pointer; display:inline-flex; align-items:center;">${globeSvg}</span>
        ${editBtnHtml}
      </span>`;
    }

    function handleEditLink(event, videoTitle, linkField, currentUrl) {
      event.stopPropagation();
      customPrompt(`Enter URL for ${linkField}:`, currentUrl, function(newUrl) {
        if (newUrl && !newUrl.startsWith('http://') && !newUrl.startsWith('https://')) {
          showToast('Invalid URL. Please make sure the link starts with http:// or https://', 'error');
          return;
        }
        
        callServer('updateStageLink', [videoTitle, linkField, newUrl], function () {
          const row = DATA.find(r => r['Video Title'] === videoTitle);
          if (row) {
            row[linkField] = newUrl;
          }
          renderAll();
          showToast('Link updated successfully!', 'success');
        }, function (err) {
          showToast('Failed to update link: ' + (err && err.error ? err.error : JSON.stringify(err)), 'error');
        });
      });
    }

    function assignDropdown(row, roleCol, teamName) {
      const disabledAttr = isAssignEditing ? '' : 'disabled';
      const key = `${row['Video Title']}|${roleCol}`;
      const selectedValue = (key in pendingAssignments) ? pendingAssignments[key] : row[roleCol];

      const lowerTeam = teamName.toLowerCase().split(' ')[0]; // matches 'creative', 'production', or 'editor'
      const options = ['<option value="">— unassigned —</option>']
        .concat(ROSTER.filter(p => p.team && p.team.toLowerCase().includes(lowerTeam)).map(p => `<option value="${p.name}" ${selectedValue === p.name ? 'selected' : ''}>${p.name}</option>`));
      const vt = row['Video Title'].replace(/'/g, "\\'");
      const onChangeAttr = isAssignEditing ? `onchange="handleAssignChange('${vt}','${roleCol}', this.value)"` : '';
      
      const linkFields = {
        'Creative Team': 'Creative Link',
        'Production Team': 'Production Link',
        'Editor': 'Editor Link'
      };
      const linkField = linkFields[roleCol];
      const linkUrl = row[linkField] || '';
      const linkHtml = getLinkIconHtml(row['Video Title'], linkField, linkUrl, false);

      return `<div style="display:flex; align-items:center; gap:6px; min-width:140px;">
        <select class="assign-select" ${disabledAttr} ${onChangeAttr} style="flex:1;">${options.join('')}</select>
      </div>`;
    }

    function handleDeleteTask(videoTitle) {
      if (!confirm(`Are you sure you want to PERMANENTLY DELETE the task "${videoTitle}"?\nThis will remove the row from Google Sheets and cannot be undone.`)) {
        return;
      }
      
      callServer('deleteTask', [videoTitle], function () {
        DATA = DATA.filter(r => r['Video Title'] !== videoTitle);
        renderAll();
        alert(`Task "${videoTitle}" deleted successfully.`);
      }, function (err) {
        alert('Failed to delete task: ' + (err && err.error ? err.error : JSON.stringify(err)));
      });
    }

    function handleResetClientTasks() {
      const clientSelect = document.getElementById('assignFilterClient');
      const selectedClient = clientSelect ? clientSelect.value : '';
      if (!selectedClient) {
        alert('Please select a client from the "All clients" dropdown first.');
        return;
      }
      
      if (!confirm(`Are you sure you want to reset Priority, Deadline, Creative, Production, Editor, and all Asset Links for ALL tasks under client "${selectedClient}"?`)) {
        return;
      }
      
      isAssignEditing = true;
      
      DATA.forEach(row => {
        if (row['Client Name'] === selectedClient) {
          const vt = row['Video Title'];
          pendingAssignments[`${vt}|Priority`] = 'Normal';
          pendingAssignments[`${vt}|Deadline`] = '';
          pendingAssignments[`${vt}|Creative Team`] = '';
          pendingAssignments[`${vt}|Production Team`] = '';
          pendingAssignments[`${vt}|Editor`] = '';
          pendingAssignments[`${vt}|Creative Link`] = '';
          pendingAssignments[`${vt}|Production Link`] = '';
          pendingAssignments[`${vt}|Editor Link`] = '';
        }
      });
      
      const btnApply = document.getElementById('btnAssignApply');
      if (btnApply) {
        btnApply.disabled = false;
      }
      
      renderAssignTab();
      alert(`Queued reset for all tasks and links under client "${selectedClient}". Click the "✓ Apply" button to save these changes.`);
    }

    function renderAssignTab() {
      if (ROLE !== 'admin') return;
      const search = (document.getElementById('assignSearch').value || '').toLowerCase().trim();
      const client = document.getElementById('assignFilterClient').value;
      let rows = DATA;
      if (client) rows = rows.filter(r => r['Client Name'] === client);
      if (search) rows = rows.filter(r => (r['Client Name'] + ' ' + r['Video Title']).toLowerCase().includes(search));

      document.getElementById('assignBody').innerHTML = rows.map(row => {
        const vt = row['Video Title'].replace(/'/g, "\\'");
        const deleteBtn = isAssignEditing 
          ? `<button class="btn small reject" onclick="handleDeleteTask('${vt}')" style="font-weight:700;">Delete</button>`
          : '<span style="color:var(--text-muted)">—</span>';
        
        return `
          <tr>
            <td>${row['Client Name']}</td>
            <td>${row['Video Title']}</td>
            <td>${priorityDropdown(row)}</td>
            <td>${deadlineInput(row)}</td>
            <td>${assignDropdown(row, 'Creative Team', 'Creative')}</td>
            <td>${assignDropdown(row, 'Production Team', 'Production')}</td>
            <td>${assignDropdown(row, 'Editor', 'Editor')}</td>
            <td style="text-align:center;">${deleteBtn}</td>
          </tr>
        `;
      }).join('') || `<tr><td colspan="8"><div class="empty-state">No videos match.</div></td></tr>`

      // Update buttons visibility
      const btnEdit = document.getElementById('btnAssignEdit');
      const btnAdd = document.getElementById('btnAssignAdd');
      const btnResetClient = document.getElementById('btnAssignResetClient');
      const btnApply = document.getElementById('btnAssignApply');
      const btnCancel = document.getElementById('btnAssignCancel');

      if (btnEdit && btnApply && btnCancel) {
        if (isAssignEditing) {
          btnEdit.style.display = 'none';
          if (btnAdd) btnAdd.style.display = 'none';
          if (btnResetClient) btnResetClient.style.display = 'none';
          btnApply.style.display = 'inline-block';
          btnCancel.style.display = 'inline-block';
          btnApply.textContent = '✓ Apply';
          btnApply.disabled = Object.keys(pendingAssignments).length === 0;
          btnCancel.disabled = false;
        } else {
          btnEdit.style.display = 'inline-block';
          if (btnAdd) btnAdd.style.display = 'inline-block';
          if (btnResetClient) btnResetClient.style.display = 'inline-block';
          btnApply.style.display = 'none';
          btnCancel.style.display = 'none';
        }
      }
    }

    // ---------- Team (browse anyone) ----------
    let selectedPerson = null;
    function renderTeamChips() {
      const counts = {};
      ROSTER.forEach(p => counts[p.name] = 0);
      DATA.forEach(row => { ['Creative Team', 'Production Team', 'Editor'].forEach(f => { const n = row[f]; if (n && counts.hasOwnProperty(n)) counts[n]++; }); });
      if (!selectedPerson) selectedPerson = ROLE === 'member' ? MY_NAME : ROSTER[0].name;
      const el = document.getElementById('teamChips');
      el.innerHTML = ROSTER.map(p => {
        const color = p.team === 'Creative' ? 'var(--role-creative)' : (p.team === 'Production' ? 'var(--role-production)' : 'var(--role-editor)');
        return `<button class="chip ${selectedPerson === p.name ? 'active' : ''}" data-name="${p.name}"><span class="role-dot" style="background:${color}"></span>${p.name} <span class="n">${counts[p.name]}</span></button>`;
      }).join('');
      el.querySelectorAll('.chip').forEach(chip => { chip.onclick = () => { selectedPerson = chip.dataset.name; renderTeamChips(); renderTeamTable(); }; });
    }
    function handleResetUserPassword(email, name) {
      customConfirm('Confirm Password Reset', `Are you sure you want to reset the password for ${name} (${email})?\nThis will clear their current password, allowing them to register a new one next time they log in.`, function () {
        callServer('resetUserPassword', [email], function () {
          showToast(`Password for ${name} has been successfully reset!`, 'success');
        });
      });
    }

    function handleDeleteTeamMember(name, email) {
      customConfirm('Confirm Delete Member', `Are you sure you want to PERMANENTLY DELETE team member "${name}"? This will clear their login details and roster registration.`, function() {
        callServer('deleteTeamMember', [name, email], function() {
          showToast(`Team member "${name}" deleted successfully!`, 'success');
          ROSTER = ROSTER.filter(p => p.name !== name);
          if (email) {
            delete TEAM_ACCOUNTS[email];
          }
