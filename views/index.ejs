    // ---------- KPIs ----------
    function renderKpis() {
      const total = DATA.length;
      let notStartedVideos = 0, checkpointsDone = 0, checkpointsProgress = 0, checkpointsTotal = 0, awaiting = 0;
      DATA.forEach(row => {
        let allNot = true;
        CHECKPOINT_FIELDS.forEach(f => {
          checkpointsTotal++;
          const c = statusCategory(row[f]);
          if (c === 'done') checkpointsDone++;
          if (c === 'progress') checkpointsProgress++;
          if (c !== 'not') allNot = false;
        });
        if (allNot) notStartedVideos++;
        STAGES.forEach(s => { if (row[s.statusField] === 'Completed' && row[s.approvalField] !== 'Approved') awaiting++; });
      });
      const unassigned = DATA.filter(r => !r['Production Team'] || !r['Editor']).length;
      const deadlineSet = DATA.filter(r => r['Deadline']).length;

      document.getElementById('kpiTotal').textContent = total;
      document.getElementById('kpiNotStarted').textContent = notStartedVideos;
      document.getElementById('kpiNotStartedPct').textContent = Math.round(notStartedVideos / total * 100) + '% of videos untouched';
      document.getElementById('kpiAwaiting').textContent = awaiting;
      document.getElementById('kpiDone').textContent = checkpointsDone;
      document.getElementById('kpiDonePct').textContent = Math.round(checkpointsDone / checkpointsTotal * 100) + '% of ' + checkpointsTotal + ' checkpoints';
      document.getElementById('kpiUnassigned').textContent = unassigned;
      document.getElementById('kpiDeadlines').textContent = deadlineSet + ' of ' + total;

      const counts = {};
      ROSTER.forEach(p => counts[p.name] = 0);
      DATA.forEach(row => { ['Creative Team', 'Production Team', 'Editor'].forEach(f => { const n = row[f]; if (n && counts.hasOwnProperty(n)) counts[n]++; }); });
      const zeroPeople = ROSTER.filter(p => counts[p.name] === 0).map(p => p.name);
      const cbox = document.getElementById('workloadCallout');
      if (zeroPeople.length) {
        cbox.style.display = 'flex';
        cbox.innerHTML = '⚠️ <div><b>Workload gap:</b> ' + zeroPeople.join(', ') + ' currently ' +
          (zeroPeople.length === 1 ? 'has' : 'have') + ' zero videos assigned. ' +
          unassigned + ' of ' + total + ' videos have no Production or Editor owner yet.' +
          (ROLE === 'admin' ? ' Fix this in the <b>Assign</b> tab.' : '') + '</div>';
      } else {
        cbox.style.display = 'none';
      }
    }

    function renderStageChart() {
      const el = document.getElementById('stageChart');
      el.innerHTML = '';
      STAGES.concat(GATE_FIELDS.map(f => ({ key: f, label: f, statusField: f }))).forEach(stage => {
        const counts = { not: 0, progress: 0, done: 0 };
        DATA.forEach(row => { counts[statusCategory(row[stage.statusField])]++; });
        const total = DATA.length;
        const row = document.createElement('div');
        row.className = 'row';
        row.innerHTML = `
      <div class="rlabel">${stage.label}</div>
      <div class="track">
        ${['not', 'progress', 'done'].map(k => {
          const pct = (counts[k] / total * 100).toFixed(1);
          if (counts[k] === 0) return '';
          const color = k === 'not' ? 'var(--status-not)' : (k === 'progress' ? 'var(--status-progress)' : 'var(--status-done)');
          const label = k === 'not' ? 'Not started' : (k === 'progress' ? 'In progress' : 'Done');
          return `<div class="seg" title="${label}: ${counts[k]} of ${total}" style="width:${pct}%;background:${color}"></div>`;
        }).join('')}
      </div>
      <div class="rvalue">${counts.done}/${total}</div>
    `;
        el.appendChild(row);
      });
    }

    function renderWorkloadChart() {
      const el = document.getElementById('workloadChart');
      el.innerHTML = '';
      const counts = {};
      ROSTER.forEach(p => counts[p.name] = 0);
      DATA.forEach(row => { ['Creative Team', 'Production Team', 'Editor'].forEach(f => { const n = row[f]; if (n && counts.hasOwnProperty(n)) counts[n]++; }); });
      const max = Math.max(1, ...Object.values(counts));
      ROSTER.forEach(p => {
        const n = counts[p.name];
        const pct = (n / max * 100).toFixed(1);
        const color = p.team === 'Creative' ? 'var(--role-creative)' : (p.team === 'Production' ? 'var(--role-production)' : 'var(--role-editor)');
        const row = document.createElement('div');
        row.className = 'row';
