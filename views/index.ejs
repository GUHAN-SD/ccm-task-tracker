    <span class="s"><b>${items.filter(it => it.row[it.stage.statusField] === 'Completed' && it.row[it.stage.approvalField] !== 'Approved').length}</b> waiting for approval</span>
    <span class="s"><b>${items.filter(it => it.row[it.stage.approvalField] === 'Approved').length}</b> approved</span>
  `;

      body.innerHTML = items.map(it => {
