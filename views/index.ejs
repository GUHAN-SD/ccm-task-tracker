          <div>
            <label style="display:block; font-size:12px; font-weight:600; margin-bottom:4px; color:var(--text-secondary);">Role / Department * (Creative / Production / Editor)</label>
            <input type="text" id="modalMemberRole" required placeholder="e.g. Creative Lead, Video Editor, Production Assistant" style="width:100%; padding:8px 10px; border-radius:8px; border:1px solid var(--border); background:var(--surface-2); color:var(--text-primary);">
          </div>
        </div>
        <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:20px;">
          <button type="button" class="btn" onclick="closeAddMemberModal()">Cancel</button>
          <button type="submit" id="btnSubmitMemberModal" class="btn primary">Add Member</button>
        </div>
      </form>
    </div>
  </div>
  <% } %>

  <!-- Dynamic Toast Notification Container -->
  <div id="toast-container" style="position: fixed; bottom: 24px; right: 24px; display: flex; flex-direction: column; gap: 10px; z-index: 9999; pointer-events: none;"></div>

  <!-- Custom Confirm Modal -->
  <div id="confirmModal" class="modal-overlay" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); backdrop-filter:blur(4px); z-index:9000; align-items:center; justify-content:center;">
    <div class="modal-card" style="background:var(--surface-1); border:1px solid var(--border); border-radius:16px; width:100%; max-width:400px; padding:24px; box-shadow:0 8px 32px rgba(0,0,0,0.4); text-align:center; animation:fadeIn 0.2s ease-out;">
      <div style="font-size:32px; margin-bottom:12px;">⚠️</div>
      <h3 id="confirmTitle" style="margin-top:0; margin-bottom:8px; font-size:16px; color:var(--text-primary); font-weight:700;">Confirm Action</h3>
      <p id="confirmMessage" style="font-size:13px; color:var(--text-secondary); margin-bottom:20px; line-height:1.5;"></p>
      <div style="display:flex; justify-content:center; gap:12px;">
        <button id="confirmCancelBtn" class="btn" style="padding:8px 16px;">Cancel</button>
        <button id="confirmOkBtn" class="btn reject" style="padding:8px 16px;">Yes, Proceed</button>
      </div>
    </div>
  </div>

  <!-- Custom Prompt Modal -->
  <div id="promptModal" class="modal-overlay" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); backdrop-filter:blur(4px); z-index:9000; align-items:center; justify-content:center;">
    <div class="modal-card" style="background:var(--surface-1); border:1px solid var(--border); border-radius:16px; width:100%; max-width:400px; padding:24px; box-shadow:0 8px 32px rgba(0,0,0,0.4); animation:fadeIn 0.2s ease-out;">
      <h3 id="promptTitle" style="margin-top:0; margin-bottom:12px; font-size:15px; color:var(--text-primary); font-weight:700;">Enter URL</h3>
      
      <!-- Text/URL Input -->
      <input type="text" id="promptInput" placeholder="https://..." style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--border); background:var(--surface-2); color:var(--text-primary); font-size:13px; margin-bottom:16px; outline:none;">
      
      <!-- Voice Recording Section (Dynamic, only shown for voice note feedback) -->
      <div id="promptVoiceSection" style="display:none; margin-bottom:20px; padding:12px; border-radius:10px; background:var(--surface-2); border:1px solid var(--border);">
        <div style="font-size:11.5px; font-weight:700; color:var(--text-secondary); margin-bottom:8px; display:flex; align-items:center; gap:6px;">
          <span style="display:inline-block; width:8px; height:8px; border-radius:50%; background:var(--text-muted);" id="recIndicator"></span>
          <span id="recStatus">Voice feedback is optional</span>
        </div>
        <div style="display:flex; align-items:center; gap:8px;">
          <button type="button" id="btnStartRec" class="btn" style="padding:6px 12px; font-size:12px; background:var(--accent); color:white; border:none; display:flex; align-items:center; gap:4px;">🎤 Record</button>
          <button type="button" id="btnStopRec" class="btn reject" style="padding:6px 12px; font-size:12px; display:none; align-items:center; gap:4px;">⏹️ Stop</button>
          <audio id="audioPreview" controls style="display:none; flex:1; height:32px; max-width:200px;"></audio>
        </div>
      </div>

      <div style="display:flex; justify-content:flex-end; gap:8px;">
        <button id="promptCancelBtn" class="btn" style="padding:6px 12px; font-size:12.5px;">Cancel</button>
        <button id="promptOkBtn" class="btn primary" style="padding:6px 12px; font-size:12.5px;">Save</button>
      </div>
    </div>
  </div>
</body>

</html>