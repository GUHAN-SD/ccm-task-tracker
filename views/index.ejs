    function parseDDMMYYYY(str) {
      if (!str) return null;
      const parts = str.trim().split('/');
      if (parts.length !== 3) return null;
      const day = parseInt(parts[0], 10);
      const month = parseInt(parts[1], 10) - 1; // 0-indexed month
      const year = parseInt(parts[2], 10);
      if (isNaN(day) || isNaN(month) || isNaN(year)) return null;
      return new Date(year, month, day);
    }

    function getDaysDiff(date1, date2) {
      const diffTime = date2.getTime() - date1.getTime();
      return Math.ceil(diffTime / (1000 * 60 * 60 * 24));
    }

    function checkDeadlineNotifications() {
      const container = document.getElementById('deadlineNotifications');
      if (!container) return;
      
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      
      const urgentTasks = [];
      
      DATA.forEach(row => {
        STAGES.forEach(stage => {
          if (row[stage.roleField] === MY_NAME) {
            const statusVal = row[stage.statusField] || '';
            const approvalVal = row[stage.approvalField] || '';
            
            if (statusVal !== 'Completed' && approvalVal !== 'Approved') {
              const deadlineStr = row['Deadline'];
              if (deadlineStr) {
                const deadlineDate = parseDDMMYYYY(deadlineStr);
                if (deadlineDate) {
                  deadlineDate.setHours(0, 0, 0, 0);
                  const daysDiff = getDaysDiff(today, deadlineDate);
                  
                  if (daysDiff <= 2) {
                    urgentTasks.push({
                      videoTitle: row['Video Title'],
                      clientName: row['Client Name'],
                      stageLabel: stage.label,
                      deadline: deadlineStr,
                      daysDiff: daysDiff
                    });
                  }
                }
              }
            }
          }
        });
      });
      
      if (urgentTasks.length === 0) {
        container.style.display = 'none';
        container.innerHTML = '';
        return;
      }
      
      container.style.display = 'block';
      container.innerHTML = `
        <div class="notification-banner">
          <div class="notification-title" style="font-size:14px; font-weight:700; color:var(--text-primary); display:flex; align-items:center; gap:8px;">
            <span>⚠️</span>
            <span>Task Deadline Alerts (${urgentTasks.length})</span>
          </div>
          <div style="display:flex; flex-direction:column; gap:8px; margin-top:8px;">
            ${urgentTasks.map(task => {
              let diffText = '';
              let badgeClass = 'progress';
              if (task.daysDiff < 0) {
                diffText = `Overdue by ${Math.abs(task.daysDiff)} days!`;
                badgeClass = 'critical';
              } else if (task.daysDiff === 0) {
                diffText = 'Due TODAY!';
                badgeClass = 'urgent';
              } else if (task.daysDiff === 1) {
                diffText = 'Due tomorrow!';
                badgeClass = 'urgent';
              } else {
                diffText = `Due in ${task.daysDiff} days`;
                badgeClass = 'progress';
              }
              
              return `
                <div class="notification-item ${task.daysDiff <= 1 ? 'urgent-task' : ''}">
                  <div>
                    <b>${task.clientName}</b> - ${task.videoTitle}
                    <div style="font-size:11.5px; color:var(--text-muted); margin-top:2px;">Stage: ${task.stageLabel}</div>
                  </div>
                  <div style="display:flex; align-items:center; gap:8px;">
                    <span style="font-weight:600; font-size:12px;">Deadline: ${task.deadline}</span>
                    <span class="badge ${badgeClass}" style="font-size:11px; padding:2px 6px;">${diffText}</span>
                  </div>
                </div>
              `;
            }).join('')}
          </div>
        </div>
      `;
    }

    // ---------- Render everything ----------
    function renderAll() {
      checkDeadlineNotifications();
